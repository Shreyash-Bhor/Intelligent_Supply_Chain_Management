generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

//User Model
model User {
  id                    String    @id @default(uuid())
  email                 String    @unique
  password              String

  isEmailVerified       Boolean   @default(false)
  isActive              Boolean   @default(true)

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  
  @@index([isActive])
}

model Warehouse {
  id               String    @id @default(uuid())
  name             String    @unique
  city             String
  pincode          String
  
  isActive         Boolean   @default(true)

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  inventories Inventory[]
}

model Inventory {
  id               String    @id @default(uuid())

  productId        String
  warehouseId      String

  availableQty     Int       @default(0)
  reservedQty      Int       @default(0)
  reorderQty       Int       @default(0)

  isReorderPending Boolean   @default(false)

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  product          Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse        Warehouse @relation(fields:[warehouseId], references: [id], onDelete: Cascade)

  @@unique([productId, warehouseId])
  @@index([productId])
  @@index([isReorderPending])
  stockReorders StockReorder[]
}

model StockReorder {
  id            String        @id @default(uuid())

  inventoryId   String
  requestedQty  Int

  status        ReorderStatus @default(PENDING)

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  inventory     Inventory     @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  @@index([status])
}

enum ReorderStatus {
  PENDING
  COMPLETED
  CANCELLED
}

model Product {
  id            String    @id @default(uuid())
  name          String 
  sku           String    @unique
  
  isActive      Boolean   @default(true)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([isActive])
  
  inventories   Inventory[]
}

model ProductDeletion {
  id            String @id @default(uuid())
  
  productId     String
  reason        Reason @default(NO_LONGER_NEEDED)

  createdAt     DateTime  @default(now())

  @@index([productId])  
}

enum Reason {
  OUT_OF_STOCK
  DEPRECATED
  NO_LONGER_NEEDED
}